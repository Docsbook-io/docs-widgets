[
  {
    "name": "openapi-renderer",
    "description": "Renders an interactive OpenAPI/Swagger API reference UI inline in the chat. Use when the user asks to view, explore, or test API endpoints.",
    "version": "1.0.0",
    "category": "developer",
    "modes": ["user"],
    "triggers": [
      "show API reference",
      "render OpenAPI spec",
      "display API docs",
      "explore API endpoints",
      "view Swagger UI",
      "browse REST API",
      "show endpoints"
    ],
    "keywords": ["openapi", "swagger", "api", "rest", "endpoints", "reference", "http", "json"],
    "discriminators": ["OpenAPI", "Swagger", "API spec", "swagger.json", "openapi.yaml"],
    "mcp_resource_uri": "ui://openapi-renderer/render",
    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docs-widgets",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docs-widgets/main/widgets/openapi-renderer/widget.html",
    "widget_url": "https://raw.githubusercontent.com/docsbook-io/docs-widgets/main/widgets/openapi-renderer/widget.html"
  },
  {
    "name": "fields-form",
    "description": "Generic admin form renderer for Docsbook workspace settings cards. Renders toggle, text, and color controls from a field definition array and posts patch updates back to the admin host. Use when the admin dashboard needs to display a declarative settings card inside a sandboxed iframe.",
    "version": "1.0.0",
    "category": "forms",
    "modes": ["admin"],
    "triggers": [
      "render admin settings form",
      "workspace settings card",
      "toggle settings",
      "fields form widget",
      "admin card form"
    ],
    "keywords": ["admin", "form", "fields", "toggle", "settings", "workspace"],
    "discriminators": ["fields-form", "admin settings", "workspace card"],
    "mcp_resource_uri": "ui://fields-form/render",
    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docs-widgets",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docs-widgets/main/widgets/fields-form/WIDGET.md",
    "widget_url": "https://raw.githubusercontent.com/docsbook-io/docs-widgets/main/widgets/fields-form/widget.html"
  },
  {
    "name": "upgrade-card",
    "description": "Renders an interactive plan upgrade card inline in chat. Shows plan comparison (Pro or Pro+) with benefits and a CTA link to the existing checkout flow.",
    "version": "1.0.0",
    "category": "conversion",
    "modes": ["user", "admin"],
    "triggers": [
      "show upgrade card",
      "upgrade to pro",
      "upgrade plan",
      "show pricing"
    ],
    "keywords": ["upgrade", "pro", "plan", "billing", "pricing", "cta", "upsell"],
    "discriminators": ["upgrade", "pro plan", "pro+ plan", "upsell"],
    "mcp_resource_uri": "ui://upgrade-card/render",
    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docsbook",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/upgrade-card/widget.html",
    "widget_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/upgrade-card/widget.html"
  },
  {
    "name": "preview-card",
    "description": "Renders a browser-window-style preview of a documentation site URL inline in chat. Shows the published docs or preview URL, falls back to an open-in-new-tab link if framing is blocked.",
    "version": "1.0.0",
    "category": "content",
    "modes": ["user", "admin"],
    "triggers": [
