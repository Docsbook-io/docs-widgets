    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docs-widgets",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docs-widgets/main/widgets/fields-form/WIDGET.md",
