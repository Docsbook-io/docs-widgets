    "keywords": ["preview", "docs", "site", "url", "embed", "iframe"],
    "discriminators": ["preview", "docs site", "published site"],
    "mcp_resource_uri": "ui://preview-card/render",
    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docsbook",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/preview-card/widget.html",
    "widget_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/preview-card/widget.html"
  },
  {
    "name": "ask-user",
    "description": "Composite interactive question widget rendered inline in chat. Renders the matching control (toggle, text, choice, confirm, toggle_with_text) based on the seed kind, and posts the user's answer back via postMessage so the host can resume the agent loop.",
    "version": "1.0.0",
    "category": "interaction",
    "modes": ["user", "admin"],
    "triggers": [
      "ask user question",
      "interactive question",
      "pick an option",
      "confirm action"
    ],
    "keywords": ["ask", "question", "choice", "confirm", "toggle", "input", "interactive"],
    "discriminators": ["ask_user", "ask user", "pick option", "confirm"],
    "mcp_resource_uri": "ui://ask-user/render",
    "requires_plan": null,
    "built_in": true,
    "author": "Docsbook",
    "repository": "https://github.com/docsbook-io/docsbook",
    "raw_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/ask-user/widget.html",
    "widget_url": "https://raw.githubusercontent.com/docsbook-io/docsbook/main/docs-widgets/widgets/ask-user/widget.html"
  }
